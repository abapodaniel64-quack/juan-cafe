# ============================================================
# JUAN CAFÉ – Apache Configuration
# File: public/.htaccess
#
# Place this file inside the `public/` directory (document root).
# Requires mod_rewrite and mod_headers to be enabled in Apache.
# ============================================================

Options -Indexes
Options -MultiViews

# ── Rewrite Engine ────────────────────────────────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # ── Force HTTPS (uncomment in production only) ─────────────────────────────
    # RewriteCond %{HTTPS} off
    # RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # ── Block hidden files (.git, .env, .DS_Store, swap files) ────────────────
    RewriteCond %{REQUEST_URI} (^\.|/\.)
    RewriteRule ^ - [F,L]

    # ── Allow real files and directories to pass through unchanged ─────────────
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # ── Route all other requests through index.php ─────────────────────────────
    RewriteRule ^ index.php [QSA,L]
</IfModule>

# ── Security Headers ──────────────────────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header unset Server
    Header always unset X-Powered-By
</IfModule>

# ── PHP Settings ──────────────────────────────────────────────────────────────
<IfModule mod_php.c>
    php_flag  expose_php            Off
    php_value session.cookie_httponly 1
    php_value session.use_strict_mode 1
    php_value session.cookie_samesite "Lax"
    php_value upload_max_filesize  2M
    php_value post_max_size        8M
</IfModule>

# ── Cache Static Assets ───────────────────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg              "access plus 1 month"
    ExpiresByType image/png               "access plus 1 month"
    ExpiresByType image/webp              "access plus 1 month"
    ExpiresByType text/css                "access plus 1 week"
    ExpiresByType application/javascript  "access plus 1 week"
</IfModule>

# ── Block sensitive file types ────────────────────────────────────────────────
<FilesMatch "\.(sql|log|sh|env|gitignore|md|lock|swp)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>
